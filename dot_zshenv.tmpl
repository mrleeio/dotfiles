# Homebrew (must be first so everything else is on PATH)
if [[ -d "/opt/homebrew" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# XDG Base Directories
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"

# Editor
export EDITOR="nvim"
export VISUAL="nvim"

# Homebrew
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_NO_AUTO_UPDATE=1

# mise shims for non-interactive shells (IDE terminals, scripts)
export PATH="$HOME/.local/share/mise/shims:$PATH"

{{ if eq .machine_name "work" -}}
# Zscaler TLS inspection — trust corporate root CA
export NODE_EXTRA_CA_CERTS="${HOME}/.ssl/zscaler_root_ca.pem"
{{ end -}}
