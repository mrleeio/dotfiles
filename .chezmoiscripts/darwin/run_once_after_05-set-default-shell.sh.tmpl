#!/bin/bash
{{ if eq .chezmoi.os "darwin" -}}
{{ template "shell-header.sh" . }}

BREW_ZSH="/opt/homebrew/bin/zsh"

if [ ! -x "$BREW_ZSH" ]; then
  echo "Homebrew zsh not found, skipping default shell change"
  exit 0
fi

if [ "$SHELL" = "$BREW_ZSH" ]; then
  echo "Default shell is already Homebrew zsh"
  exit 0
fi

if ! grep -q "$BREW_ZSH" /etc/shells; then
  echo "Adding $BREW_ZSH to /etc/shells (requires sudo)"
  echo "$BREW_ZSH" | sudo tee -a /etc/shells
fi

echo "Setting default shell to $BREW_ZSH"
chsh -s "$BREW_ZSH"

echo "Default shell set to Homebrew zsh"

{{ end -}}
